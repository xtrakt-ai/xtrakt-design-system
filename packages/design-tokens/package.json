{
  "name": "@xtrakt-ai/design-tokens",
  "version": "2.3.0",
  "description": "xtrakt canonical CSS design tokens (cogneris brand). Single source of truth for every FE — purple/cyan palette, self-hosted Geist + Instrument Serif type, dark-mode overrides, mirrored from xtrakt-site.",
  "license": "UNLICENSED",
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "src/tokens.css",
    "src/fonts",
    "stylelint-config-no-legacy-tokens.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "default": "./src/tokens.css"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "main": "src/tokens.css",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xtrakt-ai/xtrakt-design-system.git",
    "directory": "packages/design-tokens"
  },
  "keywords": [
    "xtrakt",
    "design-tokens",
    "css-variables",
    "stripe-style"
  ]
}
