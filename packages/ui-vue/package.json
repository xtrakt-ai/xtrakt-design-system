{
  "name": "@xtrakt-ai/ui-vue",
  "version": "1.5.0",
  "description": "xtrakt UI primitives for Vue 3 — XBreadcrumb, XButton, XInput, XCard, XBadge, XSkeleton, XCopyUrlButton, XBulkActionBar, XShell (app-shell sidebar+topbar), useNotifications, useExportCsv, useOptimistic, useSelection, useCan, useGlobalShortcuts.",
  "license": "UNLICENSED",
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --declaration --outDir dist"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "vue-toastification": "^2.0.0-rc.5",
    "@xtrakt-ai/design-tokens": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "vue-toastification": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0",
    "vue-router": "^4.3.0",
    "vue-toastification": "^2.0.0-rc.5",
    "vue-tsc": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xtrakt-ai/xtrakt-design-system.git",
    "directory": "packages/ui-vue"
  }
}
